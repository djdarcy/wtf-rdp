#!/bin/sh
# Pre-commit hook that:
# 1. Updates version.py with correct version info
# 2. Prevents committing private content to public branches

# Get current branch name
current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

# Get the repository root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# PART 1: Update version.py
# -------------------------
# Locate the version-sync script LAYOUT-AGNOSTICALLY. It may live flat at
# scripts/sync-versions.py (this library's original assumption) OR nested at
# scripts/repokit-common/sync-versions.py (the subtree layout most consumers
# actually use). Resolve either, then fall back to a recursive find under
# scripts/. (Hardcoding scripts/sync-versions.py silently no-ops the stamp for
# every nested-layout consumer -- the bug this generalization fixes.)
SYNC_SCRIPT=""
for _cand in "$REPO_ROOT/scripts/repokit-common/sync-versions.py" "$REPO_ROOT/scripts/sync-versions.py"; do
    [ -f "$_cand" ] && { SYNC_SCRIPT="$_cand"; break; }
done
[ -z "$SYNC_SCRIPT" ] && SYNC_SCRIPT="$(find "$REPO_ROOT/scripts" -name sync-versions.py -type f -print 2>/dev/null | head -n1)"
UPDATE_SCRIPT=""
for _cand in "$REPO_ROOT/scripts/repokit-common/update-version.sh" "$REPO_ROOT/scripts/update-version.sh"; do
    [ -f "$_cand" ] && { UPDATE_SCRIPT="$_cand"; break; }
done

if [ -n "$SYNC_SCRIPT" ] && command -v python >/dev/null 2>&1; then
    # Run in auto mode to update version before commit
    UPDATE_OUTPUT=$(python "$SYNC_SCRIPT" --auto 2>&1)
    UPDATE_EXIT=$?

    if [ $UPDATE_EXIT -eq 0 ]; then
        # Success - check if version.py was staged
        if git diff --cached --name-only | grep -q "_version.py"; then
            echo "✓ Version updated for commit"
        fi
    else
        echo "⚠ Warning: Version update failed but continuing"
    fi
elif [ -n "$UPDATE_SCRIPT" ]; then
    # Fallback to legacy bash script
    "$UPDATE_SCRIPT" --auto 2>&1 || echo "⚠ Warning: Version update failed but continuing"
fi

# PART 2: Check for private content
# -------------------------------------------------
# Define private branches where private content is allowed
case "$current_branch" in
    local|private|feature/*|feat/*|prototype/*|experiment/*|spike/*)
        echo "Checking for private content on branch: $current_branch"
        exit 0
        ;;
    main|dev|live|test|production|staging|prod|master)
        echo "🔍 Pre-Commit Check"
        echo "   Branch: $current_branch (public)"
        ;;
    *)
        echo "🔍 Pre-Commit Check"
        echo "   Branch: $current_branch (public)"
        ;;
esac

# Check for private content using patterns specific to this project.
#
# Allowlist support: if .repokit-allowlist exists in repo root, paths listed
# there (one per line, # comments allowed, blank lines OK) bypass the private-
# content regex check below. Intended for DELIBERATE move-aside artifacts that
# carry signal-bearing extensions like .bak (preserved pre-pivot source: "this
# is the old version, do not use this") which would otherwise trip the regex.
ALLOWLIST_FILE="$REPO_ROOT/.repokit-allowlist"
allowed() {
    [ -f "$ALLOWLIST_FILE" ] || return 1
    grep -v '^[[:space:]]*#' "$ALLOWLIST_FILE" | grep -v '^[[:space:]]*$' | grep -Fxq -- "$1"
}

has_private_content=0
for file in $(git diff --cached --name-only); do
    # Skip allowlisted paths
    if allowed "$file"; then
        continue
    fi
    # Check against private content patterns
    if echo "$file" | grep -q -E "^.*/__private__.*|^.*/private_.*|^.*~$|\.backup$|\.bak$|\.log$|\.tmp$|^\.env.*|^\.env\.local$|^\.env\.private$|^convos/|^credentials/|^logs/|^nul$|^private/|^revisions/|^secrets/|^test-runs/|^test_runs/"; then
        if [ $has_private_content -eq 0 ]; then
            echo ""
            echo "❌ COMMIT BLOCKED - Private Content Protection"
            echo ""
            echo "ERROR: Attempting to commit private files to public branch '$current_branch':"
            echo ""
            has_private_content=1
        fi
        echo "  - $file"
    fi
done

if [ $has_private_content -eq 1 ]; then
    echo ""
    echo "These files should only exist in private branches."
    echo "To fix this:"
    echo "  1. Switch to private branch: git checkout private"
    echo "  2. Or unstage these files: git reset HEAD <file>"
    echo "  3. Or remove from working directory: rm <file>"
    echo ""
    exit 1
fi

# Check for large files (>10MB)
for file in $(git diff --cached --name-only); do
    if [ -f "$file" ]; then
        size=$(du -k "$file" | awk '{print $1}')
        if [ "$size" -gt 10240 ]; then
            echo "ERROR: File $file is too large ($size KB)"
            echo "Consider using Git LFS or add to .gitignore"
            exit 1
        fi
    fi
done

exit 0